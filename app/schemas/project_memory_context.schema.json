{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEO Agent Project Memory Context",
  "type": "object",
  "additionalProperties": false,
  "required": ["query", "summary", "memories"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "memories": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memory_context_item"
      }
    }
  },
  "$defs": {
    "memory_context_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "uuid", "text", "summary", "created_at"],
      "properties": {
        "source": {
          "type": "string"
        },
        "uuid": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        }
      }
    }
  }
}
