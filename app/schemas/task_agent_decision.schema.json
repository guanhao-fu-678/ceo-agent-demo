{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CEO Agent Task Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "discard_reason",
    "project",
    "todo_changes",
    "follow_up_drafts",
    "update_summary",
    "merge_reason",
    "memory_recall_used",
    "confidence",
    "failure_risk",
    "failure_risk_score"
  ],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["discard", "create_project", "update_project"]
    },
    "discard_reason": {
      "type": "string"
    },
    "project": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/project"
        }
      ]
    },
    "todo_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/todo_change"
      }
    },
    "follow_up_drafts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/follow_up_draft"
      }
    },
    "update_summary": {
      "type": "string"
    },
    "merge_reason": {
      "type": "string"
    },
    "memory_recall_used": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "failure_risk": {
      "type": "string"
    },
    "failure_risk_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "source", "created", "updated"],
      "properties": {
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "created": {
          "type": "string"
        },
        "updated": {
          "type": "string"
        }
      }
    },
    "memory_context_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "uuid", "text", "summary", "created_at"],
      "properties": {
        "source": {
          "type": "string"
        },
        "uuid": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string"
        }
      }
    },
    "memory_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query", "summary", "memories"],
      "properties": {
        "query": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "memories": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/memory_context_item"
          }
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category",
        "tags",
        "status",
        "priority",
        "risk_level",
        "needs_derek_attention",
        "owner_user_id",
        "owner_name",
        "related_people",
        "goal",
        "background",
        "memory_context",
        "facts",
        "current_state",
        "blocker",
        "next_step",
        "next_follow_up_at",
        "follow_up_mode",
        "source_conversations"
      ],
      "properties": {
        "id": {
          "type": ["integer", "null"]
        },
        "title": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "management",
            "strategy",
            "projects",
            "marketing",
            "research",
            "dev",
            "product",
            "recruiting",
            "sales",
            "finance",
            "admin",
            "HR",
            "other"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": ["active", "waiting", "done", "archived"]
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "none"]
        },
        "risk_level": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        },
        "needs_derek_attention": {
          "type": "boolean"
        },
        "owner_user_id": {
          "type": "string"
        },
        "owner_name": {
          "type": "string"
        },
        "related_people": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "user_id", "role"],
            "properties": {
              "name": {
                "type": "string"
              },
              "user_id": {
                "type": "string"
              },
              "role": {
                "type": "string"
              }
            }
          }
        },
        "goal": {
          "type": "string"
        },
        "background": {
          "type": "string"
        },
        "memory_context": {
          "$ref": "#/$defs/memory_context"
        },
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact"
          }
        },
        "current_state": {
          "type": "string"
        },
        "blocker": {
          "type": "string"
        },
        "next_step": {
          "type": "string"
        },
        "next_follow_up_at": {
          "type": "string"
        },
        "follow_up_mode": {
          "type": "string",
          "enum": ["auto", "draft", "none"]
        },
        "source_conversations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["conversation_id", "title", "kind", "source_ref"],
            "properties": {
              "conversation_id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "source_ref": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "todo_change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "todo_id",
        "todo_ref",
        "title",
        "owner_user_id",
        "owner_name",
        "status",
        "priority",
        "deadline_at",
        "next_follow_up_at",
        "follow_up_question",
        "completion_evidence",
        "blocker"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["create", "update", "close", "cancel"]
        },
        "todo_id": {
          "type": ["integer", "null"]
        },
        "todo_ref": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "owner_user_id": {
          "type": "string"
        },
        "owner_name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["open", "waiting_owner", "done", "cancelled"]
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "none"]
        },
        "deadline_at": {
          "type": "string"
        },
        "next_follow_up_at": {
          "type": "string"
        },
        "follow_up_question": {
          "type": "string"
        },
        "completion_evidence": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["description", "source", "completed_at"],
          "properties": {
            "description": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "completed_at": {
              "type": "string"
            }
          }
        },
        "blocker": {
          "type": "string"
        }
      }
    },
    "follow_up_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "todo_id",
        "todo_ref",
        "owner_user_id",
        "owner_name",
        "target_conversation_id",
        "target_kind",
        "question_text",
        "scheduled_at",
        "risk_check",
        "status"
      ],
      "properties": {
        "todo_id": {
          "type": ["integer", "null"]
        },
        "todo_ref": {
          "type": "string"
        },
        "owner_user_id": {
          "type": "string",
          "minLength": 1
        },
        "owner_name": {
          "type": "string"
        },
        "target_conversation_id": {
          "type": "string"
        },
        "target_kind": {
          "type": "string",
          "enum": ["group", "direct"]
        },
        "question_text": {
          "type": "string"
        },
        "scheduled_at": {
          "type": "string"
        },
        "risk_check": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sensitive", "owner_in_group", "reason"],
          "properties": {
            "sensitive": {
              "type": "boolean"
            },
            "owner_in_group": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "status": {
          "type": "string",
          "enum": ["draft", "approved", "sent", "skipped", "failed", "cancelled"]
        }
      }
    }
  }
}
